# MusicGrabber Environment Variables Example
# Copy this file to .env and configure your settings

# =============================================================================
# Telegram Bot (required for bot functionality)
# =============================================================================
# Get token from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Restrict bot access to specific users (comma-separated chat IDs)
# Leave empty to allow all users (default)
# Get your chat ID from @userinfobot
TELEGRAM_ALLOWED_USERS=

# =============================================================================
# Basic Configuration
# =============================================================================
# Music directory path inside container
MUSIC_DIR=/music

# Database path
DB_PATH=/data/music_grabber.db

# Default: Convert downloads to FLAC
DEFAULT_CONVERT_TO_FLAC=true

# =============================================================================
# Optional: Run as specific user (like *arr stack)
# =============================================================================
# PUID=1000
# PGID=1000

# =============================================================================
# Optional: Navidrome Integration
# =============================================================================
# NAVIDROME_URL=http://navidrome:4533
# NAVIDROME_USER=admin
# NAVIDROME_PASS=yourpassword

# =============================================================================
# Optional: Jellyfin Integration
# =============================================================================
# JELLYFIN_URL=http://jellyfin:8096
# JELLYFIN_API_KEY=your-jellyfin-api-key

# =============================================================================
# Optional: Soulseek Integration
# =============================================================================
# SLSKD_URL=http://slskd:5030
# SLSKD_USER=username
# SLSKD_PASS=password
# SLSKD_DOWNLOADS_PATH=/downloads

# =============================================================================
# Optional: Notifications
# =============================================================================
# Telegram webhook for download notifications
# TELEGRAM_WEBHOOK_URL=https://api.telegram.org/bot{token}/sendMessage?chat_id={chat_id}

# Generic webhook URL
# WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# Email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# SMTP_FROM=musicgrabber@example.com
# SMTP_TO=you@example.com
# SMTP_TLS=true

# What to notify about (comma-separated): singles,playlists,bulk,errors
# NOTIFY_ON=playlists,bulk,errors

# =============================================================================
# Optional: Features
# =============================================================================
# ENABLE_MUSICBRAINZ=true
# ENABLE_LYRICS=true
# API_KEY=your-api-key-for-web-ui-authentication
